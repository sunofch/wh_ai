# Python 运行缓存 
__pycache__/
*.py[cod]
*$py.class

# Claude 相关配置文件 (根据你的要求隐藏) 
.claude/
CLAUDE.md

# 数据与模型存储 (排除运行生成的存储数据) 
# 忽略整个 data 文件夹下的动态生成内容
data/vector_db/
data/graph_db/storage/
# 如果 models 文件夹下也是运行生成的模型，建议也忽略
models/

# 日志与缓存 
*.log
.cache/

# 虚拟环境 
venv/
env/

# 操作系统与 IDE 
.DS_Store
.vscode/
.idea/

# 敏感环境配置文件
.env

# vLLM Server PID 文件
.vlm_server.piddocs/
