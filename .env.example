# ====================
# 模型配置
# ====================
ASR_MODEL=large-v3-turbo
ASR_DEVICE=auto
ASR_LANGUAGE=zh

VLM_MODEL=Qwen/Qwen2-VL-2B-Instruct
VLM_DEVICE=auto
VLM_MAX_TOKENS=512

# VLM 模型类型选择: qwen2 或 qwen35
VLM_MODEL_TYPE=qwen2

# Qwen3.5-9B VLM 配置
VLM35_MODEL=Qwen/Qwen3.5-4B
VLM35_DEVICE=auto
VLM35_MAX_TOKENS=4096

# ====================
# 解析器配置
# ====================
PARSER_FALLBACK_PART_NAME=未知备件
PARSER_FALLBACK_DESCRIPTION_PREFIX=自动解析失败，原始信息

# ====================
# 路径配置
# ====================
CACHE_DIR=./models
OUTPUT_DIR=./output
KNOWLEDGE_BASE_PATH=./data/knowledge_base
VECTOR_DB_PATH=./data/vector_db
GRAPH_DB_PATH=./data/graph_db

# ====================
# RAG 配置
# ====================
RAG_ENABLED=true
RAG_GRAPH_ENABLED=true
RAG_EMBEDDING_MODEL=BAAI/bge-m3
RAG_DEVICE=auto
RAG_TOP_K=3

# ====================
# RAG 检索配置
# ====================
RAG_RETRIEVAL_MODE=hybrid
RAG_RETRIEVAL_THRESHOLD_STRICT=0.7
RAG_RETRIEVAL_THRESHOLD_MEDIUM=0.35
RAG_RETRIEVAL_THRESHOLD_RELAXED=0.25
RAG_RETRIEVAL_MIN_RESULTS_EXPECTED=2
RAG_RETRIEVAL_HYBRID_ENABLED=true
RAG_RETRIEVAL_FUSION_METHOD=rrf
RAG_RETRIEVAL_VECTOR_WEIGHT=0.7
RAG_RETRIEVAL_KEYWORD_WEIGHT=0.3

# ====================
# RAG 重排序配置
# ====================
RAG_RERANK_ENABLED=true
RAG_RERANK_MODEL=BAAI/bge-reranker-v2-m3
RAG_RERANK_TOP_K=10
RAG_RERANK_FINAL_TOP_K=3
RAG_RERANK_DEVICE=auto

# ====================
# RAG 分块配置
# ====================
RAG_CHUNKING_STRATEGY=semantic
RAG_CHUNKING_CHUNK_SIZE=1024
RAG_CHUNKING_CHUNK_OVERLAP=128
RAG_CHUNKING_SEMANTIC_SPLITTER_THRESHOLD=0.6
RAG_CHUNKING_MIN_CHUNK_SIZE=128
RAG_CHUNKING_MARKDOWN_ENABLED=true
RAG_CHUNKING_MARKDOWN_HEADING_LEVEL=2
RAG_CHUNKING_MARKDOWN_PRESERVE_TABLES=true
RAG_CHUNKING_METADATA_INCLUDE_HEADING=true
RAG_CHUNKING_METADATA_INCLUDE_POSITION=false

# ====================
# GraphRAG 配置
# ====================
GRAPH_RAG_EXTRACTOR_TYPE=dynamic
GRAPH_RAG_MAX_TRIPLETS_PER_CHUNK=15
GRAPH_RAG_NUM_WORKERS=4
GRAPH_RAG_ENTITY_HINTS=港口设备,系统机构,备件零件,规格型号,存放库位
GRAPH_RAG_RELATION_HINTS=包含,属于,规格为,存放于,别名为
GRAPH_RAG_LLM_PROVIDER=deepseek
GRAPH_RAG_DEEPSEEK_API_KEY=your-api-key-here
GRAPH_RAG_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
GRAPH_RAG_DEEPSEEK_MODEL=deepseek-chat
GRAPH_RAG_DEEPSEEK_TEMPERATURE=0.7

# ====================
# 图谱检索配置
# ====================
GRAPH_RETRIEVAL_SUB_RETRIEVERS=vector,synonym
GRAPH_RETRIEVAL_VECTOR_TOP_K=5
GRAPH_RETRIEVAL_VECTOR_PATH_DEPTH=1
GRAPH_RETRIEVAL_SYNONYM_MAX_KEYWORDS=8
GRAPH_RETRIEVAL_SYNONYM_PATH_DEPTH=1

# ====================
# GraphRAG Reranker 配置
# ====================
GRAPH_RERANK_ENABLED=false
GRAPH_RERANK_TOP_K=10
GRAPH_RERANK_FINAL_TOP_K=3

# ====================
# 图谱性能配置
# ====================
GRAPH_QUERY_CACHE_TTL=3600
GRAPH_CACHE_MAX_SIZE=100

# ====================
# vLLM服务器配置
# ====================
VLLM_SERVER_ENABLED=true
VLLM_SERVER_HOST=localhost
VLLM_SERVER_BASE_PORT=8000
VLLM_SERVER_TP_SIZE=1
VLLM_SERVER_GPU_MEM_UTIL=0.5
VLLM_SERVER_STARTUP_TIMEOUT=180
# VLLM_SERVER_MAX_MODEL_LEN=8192  # 可选，不设置则使用模型默认值
VLLM_SERVER_LIMIT_MM_PER_PROMPT={"image": 4}
